# NewsMind AI - Environment Settings Example

# General Environment
ENV=development
DEBUG=true
PORT=8000
HOST=0.0.0.0
CORS_ORIGINS=["http://localhost:5173", "http://127.0.0.1:5173"]

# Security & JWT
JWT_SECRET=super_secret_unbreakable_jwt_signing_key_change_me_in_production
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Databases
DATABASE_URL=sqlite+aiosqlite:///./newsmind.db
CHROMA_DB_PATH=./chromadb_data

# AI & LLM Settings
OLLAMA_URL=http://localhost:11434
DEFAULT_LLM_MODEL=qwen2.5:7b
EMBEDDING_MODEL=all-minilm:latest

# Email SMTP Settings (Gmail Example)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_specific_password_here
EMAIL_FROM=newsmind-ai@yourdomain.com

# External Service APIs
OPENWEATHER_API_KEY=your_openweather_api_key_optional
NEWS_API_KEY=your_news_api_key_optional
